{
  "manifest_version": 3,
  "name": "Classroom Helper",
  "version": "0.5.3",
  "description": "Google Classroom の学習・授業閲覧を効率化する Chrome 拡張。動画文字起こし、添付資料ダウンロード、期限管理を補助。",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "downloads",
    "notifications",
    "offscreen",
    "storage"
  ],
  "host_permissions": [
    "https://classroom.google.com/*",
    "https://drive.google.com/*",
    "https://docs.google.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://classroom.google.com/*",
        "https://drive.google.com/*",
        "https://docs.google.com/*"
      ],
      "js": [
        "src/content/shared.js",
        "src/content/due-parser.js",
        "src/content/due-card-sorter.js",
        "src/content/due-highlights.js",
        "src/content/transcript.js",
        "src/content/attachments.js"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Classroom Helper"
  },
  "minimum_chrome_version": "109"
}
